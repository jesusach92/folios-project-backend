{
    "name": "production-control-backend",
    "version": "1.0.0",
    "description": "Backend MVP para Sistema de Control de Cadena de Producción",
    "main": "build/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only ./src/server.ts",
        "build": "tsc",
        "start": "node build/server.js",
        "typecheck": "tsc --noEmit",
        "seed": "ts-node scripts/seedData.ts",
        "seed:clean": "ts-node scripts/seedData.ts",
        "seed:reset": "ts-node scripts/seedData.ts -- --clear-data"
    },
    "keywords": [
        "production",
        "backend",
        "express",
        "typescript"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "mysql2": "^3.6.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/node": "^20.3.1",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.1.3"
    }
}